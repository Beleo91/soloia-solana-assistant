# ─── Image Hosting (Imgbb CDN) ────────────────────────────────────────────────
# Get your free API key at: https://imgbb.com/signup → API → Add API key
# When set, ALL uploaded images (store banners, avatars, product photos) are sent
# to Imgbb and stored as permanent public URLs instead of base64 in localStorage.
# This is REQUIRED for images to persist on Vercel (or any other deployment).
# Without this key, images still work locally but only in the browser they were uploaded in.
VITE_IMGBB_API_KEY=your_imgbb_api_key_here
