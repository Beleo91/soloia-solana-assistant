# ─── Backend API URL ──────────────────────────────────────────────────────────
# Public URL of the Replit api-server.
# When set, ALL image uploads (store banners, avatars, product photos) are sent
# to the api-server, stored on disk, and returned as permanent https:// URLs.
# This is the RECOMMENDED option for Vercel — just point to your Replit backend.
# Example: https://e898c509-974a-421b-a8ff-13bff686ac45-00-3b2e3dyboy9k.kirk.replit.dev
VITE_API_URL=https://your-replit-api-server-url-here

# ─── Image Hosting fallback (Imgbb CDN) ───────────────────────────────────────
# Only used if VITE_API_URL is NOT set.
# Get your free API key at: https://imgbb.com/signup → API → Add API key
VITE_IMGBB_API_KEY=your_imgbb_api_key_here
